<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background color of the bubble -->
    <solid android:color="@color/my_msg_clr" />

    <!-- Adjust radius to make corners rounded -->
    <!-- Use individual corner radii to make one corner sharp for the 'tail' -->
    <corners
        android:radius="16dp"
        android:bottomRightRadius="2dp" />

    <!-- Optional: Add internal spacing for the text -->
    <padding
        android:left="12dp"
        android:top="8dp"
        android:right="12dp"
        android:bottom="8dp" />
</shape>