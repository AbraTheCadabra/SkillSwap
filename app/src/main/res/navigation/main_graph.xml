<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_graph"
    app:startDestination="@id/nav_chats">

    <fragment
        android:id="@+id/nav_account"
        android:name="com.samsungit.skillswap.AccountFragment"
        android:label="AccountFragment"
        tools:layout="@layout/account_fragment"
        >
        <action
            android:id="@+id/action_nav_account_to_myListingsFragment"
            app:destination="@id/myListingsFragment" />
    </fragment>
    <fragment
        android:id="@+id/nav_chats"
        android:name="com.samsungit.skillswap.ChatsFragment"
        android:label="ChatsFragment"
        tools:layout="@layout/chats_fragment"
        >
        <action
            android:id="@+id/action_nav_chats_to_chatFragment"
            app:destination="@id/chatFragment" />
    </fragment>
    <fragment
        android:id="@+id/nav_listings"
        android:name="com.samsungit.skillswap.ListingsFragment"
        android:label="ListingsFragment"
        tools:layout="@layout/listings_fragment"
        >
        <action
            android:id="@+id/action_nav_listings_to_chatFragment"
            app:destination="@id/chatFragment" />
    </fragment>
    <fragment
        android:id="@+id/myListingsFragment"
        android:name="com.samsungit.skillswap.MyListingsFragment"
        android:label="MyListingsFragment" >
        <action
            android:id="@+id/action_myListingsFragment_to_nav_account"
            app:destination="@id/nav_account" />
        <action
            android:id="@+id/action_myListingsFragment_to_createListingFragment"
            app:destination="@id/createListingFragment" />
    </fragment>
    <fragment
        android:id="@+id/createListingFragment"
        android:name="com.samsungit.skillswap.CreateListingFragment"
        android:label="CreateListingFragment" >
        <action
            android:id="@+id/action_createListingFragment_to_myListingsFragment"
            app:destination="@id/myListingsFragment" />
    </fragment>
    <fragment
        android:id="@+id/chatFragment"
        android:name="com.samsungit.skillswap.ChatFragment"
        android:label="ChatFragment" >
        <action
            android:id="@+id/action_chatFragment_to_nav_listings"
            app:destination="@id/nav_listings" />
        <action
            android:id="@+id/action_chatFragment_to_nav_chats"
            app:destination="@id/nav_chats" />
    </fragment>
</navigation>